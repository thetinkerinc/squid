{
	"name": "squid",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "run-p mailpit dev:*",
		"dev:web": "vite dev",
		"dev:db": "bunx gel watch --migrate",
		"build": "vite build",
		"preview": "dotenvx run -- vite preview --port 5173",
		"generate": "run-p gen:*",
		"gen:interfaces": "bunx @gel/generate interfaces",
		"gen:client": "bunx @gel/generate edgeql-js",
		"cleanup": "run-s format lint check",
		"check": "svelte-kit sync && sv check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && sv check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"format": "prettier --write .",
		"mailpit": "./mailpit"
	},
	"devDependencies": {
		"@dotenvx/dotenvx": "^1.40.0",
		"@internationalized/date": "^3.8.0",
		"@lucide/svelte": "^0.488.0",
		"@sveltejs/adapter-netlify": "^5.0.0",
		"@sveltejs/kit": "^2.20.7",
		"@sveltejs/vite-plugin-svelte": "^5.0.3",
		"@tailwindcss/aspect-ratio": "^0.4.2",
		"@tailwindcss/container-queries": "^0.1.1",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.16",
		"@trigger.dev/build": "^3.3.17",
		"@types/eslint": "^9.6.1",
		"autoprefixer": "^10.4.21",
		"bits-ui": "^1.3.19",
		"clsx": "^2.1.1",
		"eslint": "^9.24.0",
		"eslint-config-prettier": "^10.1.2",
		"eslint-plugin-svelte": "^3.5.1",
		"globals": "^16.0.0",
		"lucide-svelte": "^0.488.0",
		"mode-watcher": "^0.5.1",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.5.3",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"sv": "^0.8.1",
		"svelte": "^5.27.0",
		"svelte-check": "^4.1.6",
		"svelte-sonner": "^0.3.28",
		"tailwind-merge": "2.6.0",
		"tailwind-variants": "^0.3.1",
		"tailwindcss": "3.4.17",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "^5.8.3",
		"typescript-eslint": "^8.30.1",
		"vite": "^6.3.0"
	},
	"dependencies": {
		"@gel/auth-sveltekit": "^0.4.0-canary.20250411T151858",
		"@gel/generate": "^0.6.2",
		"@infisical/sdk": "^3.0.9",
		"@inlang/paraglide-sveltekit": "^0.16.1",
		"@thetinkerinc/isolocal": "^0.1.1",
		"@trigger.dev/sdk": "^3.3.17",
		"@trpc/client": "^11.1.0",
		"@trpc/server": "^11.1.0",
		"@types/js-cookie": "^3.0.6",
		"better-auth": "^1.2.7",
		"dayjs": "^1.11.13",
		"devalue": "^5.1.1",
		"echarts": "^5.6.0",
		"gel": "^2.0.2",
		"gel-better-auth": "^0.1.242",
		"js-cookie": "^3.0.5",
