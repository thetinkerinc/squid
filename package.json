{
	"name": "foraday",
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "run-p mailpit dev:*",
		"dev:web": "vite dev",
		"dev:db": "bunx edgedb watch",
		"build": "vite build",
		"preview": "vite preview",
		"generate": "run-p gen:*",
		"gen:interfaces": "bunx @edgedb/generate interfaces",
		"gen:client": "bunx @edgedb/generate edgeql-js",
		"cleanup": "run-s format lint check",
		"check": "svelte-kit sync && sv check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && sv check --tsconfig ./tsconfig.json --watch",
		"lint": "eslint .",
		"format": "prettier --write .",
		"mailpit": "./mailpit"
	},
	"devDependencies": {
		"@sveltejs/adapter-auto": "^4.0.0",
		"@sveltejs/kit": "^2.17.1",
		"@sveltejs/vite-plugin-svelte": "^5.0.3",
		"@tailwindcss/aspect-ratio": "^0.4.2",
		"@tailwindcss/container-queries": "^0.1.1",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.16",
		"@trigger.dev/build": "^3.3.14",
		"@types/eslint": "^9.6.1",
		"autoprefixer": "^10.4.20",
		"bits-ui": "^1.0.0-next.94",
		"clsx": "^2.1.1",
		"eslint": "^9.20.0",
		"eslint-config-prettier": "^10.0.1",
		"eslint-plugin-svelte": "^2.46.1",
		"globals": "^15.14.0",
		"lucide-svelte": "^0.475.0",
		"mode-watcher": "^0.5.1",
		"npm-run-all": "^4.1.5",
		"prettier": "^3.5.0",
		"prettier-plugin-svelte": "^3.3.3",
		"prettier-plugin-tailwindcss": "^0.6.11",
		"sv": "^0.6.21",
		"svelte": "^5.19.10",
		"svelte-check": "^4.1.4",
		"svelte-sonner": "^0.3.28",
		"tailwind-merge": "2.6.0",
		"tailwind-variants": "^0.3.1",
		"tailwindcss": "3.4.17",
		"tailwindcss-animate": "^1.0.7",
		"typescript": "^5.7.3",
		"typescript-eslint": "^8.24.0",
		"vite": "^6.1.0"
	},
	"dependencies": {
		"@edgedb/auth-sveltekit": "^0.2.3",
		"@edgedb/generate": "^0.5.6",
		"@inlang/paraglide-sveltekit": "^0.15.5",
		"@trigger.dev/sdk": "^3.3.14",
		"@trpc/client": "^11.0.0-rc.761",
		"@trpc/server": "^11.0.0-rc.761",
		"@types/js-cookie": "^3.0.6",
		"chart.js": "^4.4.7",
		"dayjs": "^1.11.13",
		"devalue": "^5.1.1",
		"edgedb": "^1.5.12",
		"js-cookie": "^3.0.5",
		"radashi": "^12.3.4",
		"zod": "^3.24.1"
	}
